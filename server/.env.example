# App
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/prospectmind

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_REFRESH_SECRET=your_refresh_secret_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google Gemini API
# Get a FREE key at: https://aistudio.google.com/app/apikey
# Free tier: 15 req/min, 1M tokens/day (more than enough for dev)
GEMINI_API_KEY=AIza...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Resend (Email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@prospectmind.ai

# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# External APIs (optional enrichment sources)
SERPER_API_KEY=
HUNTER_API_KEY=
GITHUB_TOKEN=
