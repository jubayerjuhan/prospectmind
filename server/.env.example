# App
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/prospectmind

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_REFRESH_SECRET=your_refresh_secret_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Groq API
# Get a key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-120b,qwen/qwen3-32b,openai/gpt-oss-20b,llama-3.1-8b-instant

# Gemini API — primary provider (Groq currently on hold, see claudeClient.js GROQ_ENABLED)
# Preferred: Vertex AI, billed against a GCP project's billing account.
#   Requires `gcloud auth application-default login` (or a service account) with the
#   Vertex AI User role on the project, and the Vertex AI API enabled.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Fallback: AI Studio API key, used only if GOOGLE_CLOUD_PROJECT is unset. Separate prepay
# billing pool from Vertex AI — get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-1.5-flash

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Resend (Email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@prospectmind.ai

# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# External APIs (optional enrichment sources)
SERPER_API_KEY=
HUNTER_API_KEY=
GITHUB_TOKEN=
